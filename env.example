NEXT_PUBLIC_SITE_URL=

# Capacitor native kabuk (APK/IPA) — canlı site kökü; boşsa NEXT_PUBLIC_SITE_URL kullanılır
# CAPACITOR_SERVER_URL=https://siteyonetim.ornek.workers.dev

# İndirme bağlantıları (Site Yönetimi — giriş / sakin / yönetici)
# NEXT_PUBLIC_SITE_DOWNLOAD_IOS=https://apps.apple.com/...
# NEXT_PUBLIC_SITE_DOWNLOAD_ANDROID=https://play.google.com/... veya APK URL
# NEXT_PUBLIC_SITE_DOWNLOAD_WINDOWS=https://... veya Microsoft Store
# NEXT_PUBLIC_SITE_DOWNLOAD_LINUX=https://... (.AppImage / .deb)

# Süper yönetici uygulaması (ayrı paket)
# NEXT_PUBLIC_SUPER_DOWNLOAD_IOS=
# NEXT_PUBLIC_SUPER_DOWNLOAD_ANDROID=
# NEXT_PUBLIC_SUPER_DOWNLOAD_WINDOWS=
# NEXT_PUBLIC_SUPER_DOWNLOAD_LINUX=

# Canlı üretim: SQLite dosyasının sunucuda KALICI bir yolu (volume/mount).
# Boş bırakılırsa proje köküne göre data/siteyonetim.db kullanılır — konteynerlerde
# yeniden deploy sonrası veri kaybolmaması için mutlaka volume veya mutlak yol verin.
# DATABASE_PATH=/var/lib/siteyonetim/siteyonetim.db

# İlk kurulum (GET /api/seed): yalnızca tablolar boşken; .env ile ilk site + süper yönetici
INITIAL_SUPER_ADMIN_LOGIN=
INITIAL_SUPER_ADMIN_PASSWORD=
INITIAL_SITE_NAME=
# INITIAL_SITE_ADDRESS=
# INITIAL_SUPER_ADMIN_NAME=
# INITIAL_SUPER_ADMIN_MUST_CHANGE_PASSWORD=1

# JWT imzası — üretimde zorunlu
# JWT_SECRET=

# E-posta — Google Gmail (önerilen, Cloudflare Workers uyumlu)
# Google Cloud Console → Gmail API + OAuth Desktop client
# Yerelde bir kez: npm run gmail:setup  → refresh token alın
# GMAIL_CLIENT_ID=....apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-...
# GMAIL_REFRESH_TOKEN=1//...
# GMAIL_FROM=ccode4779@gmail.com
# EMAIL_REPLY_TO=ccode4779@gmail.com

# Alternatif: Resend (Gmail yoksa yedek)
# RESEND_API_KEY=re_...
# EMAIL_FROM="Site Yönetimi <onboarding@resend.dev>"

# Cloudflare Workers + D1 (OpenNext kullanan dağıtımda uygulanır — yerel SQLite satırına gerek kalmaz)
# wrangler.toml içinde [[d1_databases]] binding = "DB" olmalıdır.
# npx wrangler login
# npm run db:d1:remote

# Iyzico Ödeme Entegrasyonu
# Sandbox: https://sandbox.iyzipay.com/overdemo/giris
# Canlı: https://panel.iyzipay.com/
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
