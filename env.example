NEXT_PUBLIC_SITE_URL=

# Capacitor native kabuk (APK/IPA) — canlı site kökü; boşsa NEXT_PUBLIC_SITE_URL kullanılır
# CAPACITOR_SERVER_URL=https://siteyonetim.ornek.workers.dev

# Canlı üretim: SQLite dosyasının sunucuda KALICI bir yolu (volume/mount).
# Boş bırakılırsa proje köküne göre data/siteyonetim.db kullanılır — konteynerlerde
# yeniden deploy sonrası veri kaybolmaması için mutlaka volume veya mutlak yol verin.
# DATABASE_PATH=/var/lib/siteyonetim/siteyonetim.db

# İlk kurulum (GET /api/seed): yalnızca tablolar boşken; .env ile ilk site + süper yönetici
INITIAL_SUPER_ADMIN_LOGIN=
INITIAL_SUPER_ADMIN_PASSWORD=
INITIAL_SITE_NAME=
# INITIAL_SITE_ADDRESS=
# INITIAL_SUPER_ADMIN_NAME=
# INITIAL_SUPER_ADMIN_MUST_CHANGE_PASSWORD=1

# JWT imzası — üretimde zorunlu
# JWT_SECRET=

# Süper yönetici şifre sıfırlama e-postası (Resend)
# RESEND_API_KEY=
# EMAIL_FROM="Site Yönetim <onboarding@resend.dev>"

# Cloudflare Workers + D1 (OpenNext kullanan dağıtımda uygulanır — yerel SQLite satırına gerek kalmaz)
# wrangler.toml içinde [[d1_databases]] binding = "DB" olmalıdır.
# npx wrangler login
# npm run db:d1:remote
