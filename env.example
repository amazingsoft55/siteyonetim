# Üretimde SEO/sitemap/canonical ve istemci tarafı API adresi (Workers kökü: https://....workers.dev)
NEXT_PUBLIC_SITE_URL=

# İlk kurulum (GET /api/seed) — yalnızca boş DB'de bir kez; kodda sabit şifre yok
INITIAL_SUPER_ADMIN_LOGIN=
INITIAL_SUPER_ADMIN_PASSWORD=
INITIAL_SITE_NAME=
# INITIAL_SITE_ADDRESS=
# INITIAL_SUPER_ADMIN_NAME=
# İlk girişte kalıcı şifre ekranı (/sifre-belirle): 1 veya true
# INITIAL_SUPER_ADMIN_MUST_CHANGE_PASSWORD=1

# JWT imzası — üretimde zorunlu; değişince tüm oturumlar düşer
# JWT_SECRET=

# Süper yönetici şifre sıfırlama e-postası (Resend)
# RESEND_API_KEY=
# EMAIL_FROM="Site Yönetim <onboarding@resend.dev>"

# Lighthouse / PageSpeed Insights (sunucuda sadece; süper admin "Lighthouse güncelle" için)
GOOGLE_PAGESPEED_API_KEY=

# Yerelde setupDevPlatform'u kapamak için (normalde kullanmayın)
# SKIP_DEV_PLATFORM=1

# (İsteğe bağlı — teşhis yanıtları) Cloudflare'deki D1 panosu ile wrangler.toml aynı kalsın; gerçek erişim env.DB bağlamasıyla.
# Üretimde wrangler.toml [vars] veya Workers ayarlarında da tanımlanabilir.
# D1_DATABASE_ID=c8b48f81-826f-4e7e-a1f9-580afa5321b5
# D1_DATABASE_NAME=siteyonetim-db
