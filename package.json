{
  "name": "siteyonetim",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "db:apply": "node scripts/apply-schema.mjs",
    "db:d1:remote": "wrangler d1 execute siteyon --remote --file drizzle/full-schema.sql",
    "build": "node scripts/workers-build.mjs",
    "build:cf": "node scripts/build-cf.mjs",
    "ci:cloudflare": "npm run build:cf && wrangler deploy",
    "build:next": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "mobile:setup": "node scripts/setup-mobile.mjs",
    "mobile:sync": "npx cap sync --config capacitor.config.ts",
    "mobile:sync:super": "npx cap sync --config capacitor.super-admin.config.ts",
    "mobile:android": "npx cap open android --config capacitor.config.ts",
    "mobile:android:super": "npx cap open android --config capacitor.super-admin.config.ts",
    "mobile:ios": "npx cap open ios --config capacitor.config.ts",
    "mobile:ios:super": "npx cap open ios --config capacitor.super-admin.config.ts",
    "build:mobile": "node scripts/setup-mobile.mjs",
    "lint": "eslint",
    "gmail:setup": "node scripts/gmail-oauth-setup.mjs",
    "gmail:auth-url": "node scripts/gmail-print-auth-url.mjs",
    "deploy:noop": "node -e \"console.log('[siteyonetim] Workers deploy skipped; use Node hosting. See README.');\""
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@opennextjs/cloudflare": "^1.19.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.100.14",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dexie": "^4.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.474.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "wrangler": "^4.95.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
