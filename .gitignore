# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# npm / package manager caches (do not upload)
.npm/
.yarn/cache
.yarn/install-state.gz
.pnpm-store/

# testing
/coverage
*.lcov

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# deploy / hosting local state
.vercel
.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts
